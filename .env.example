# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=netmap
POSTGRES_PASSWORD=netmap123        # Altere em produção!
POSTGRES_DB=netmap

# ── InfluxDB ─────────────────────────────────────────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=netmap-super-secret-token   # Altere em produção!
INFLUXDB_ORG=netmap
INFLUXDB_BUCKET=network_metrics

# ── SNMP Defaults ─────────────────────────────────────────────────────────────
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT=5
SNMP_RETRIES=2
SNMP_PORT=161

# ── Polling Intervals (segundos) ──────────────────────────────────────────────
POLL_INTERVAL_STATUS=30
POLL_INTERVAL_INTERFACES=60
POLL_INTERVAL_DISCOVERY=300

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
